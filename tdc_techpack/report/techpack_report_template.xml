<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_techpack_template">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="o">
<t t-call="web.external_layout">

<div class="page" style="font-family: Arial, sans-serif; font-size: 11px; color: #111;">

    <!-- ══════════════════════════════════════════════════════
         HEADER BLOCK
    ══════════════════════════════════════════════════════ -->
    <table width="100%" style="border-collapse: collapse; border: 1.5px solid #222; margin-bottom: 0;">
        <tr>
            <td style="padding: 5px 8px; border: 1px solid #222; width: 20%;">
                <strong>BRAND:</strong>
                <span t-out="o.brand" style="margin-left:4px;"/>
            </td>
            <td style="padding: 5px 8px; border: 1px solid #222; width: 25%;">
                <strong>STYLE NO.</strong>
                <span t-out="o.style_no" style="margin-left:4px;"/>
            </td>
            <td style="padding: 5px 8px; border: 1px solid #222; width: 30%;">
                <strong>FABRIC:</strong>
                <span t-out="o.fabric" style="margin-left:4px;"/>
            </td>
            <td style="padding: 5px 8px; border: 1px solid #222; width: 25%;">
                <strong>DATE:</strong>
                <span t-out="o.date" style="margin-left:4px;"/>
            </td>
        </tr>
        <tr>
            <td style="padding: 5px 8px; border: 1px solid #222;">
                <strong>SEASON:</strong>
                <span t-out="o.season" style="margin-left:4px;"/>
            </td>
            <td style="padding: 5px 8px; border: 1px solid #222;">
                <strong>DESCRIPTION:</strong>
                <span t-out="o.description" style="margin-left:4px;"/>
            </td>
            <td colspan="2" style="padding: 5px 8px; border: 1px solid #222;">
                <strong>SIZE:</strong>
                <span t-out="o.size_range" style="margin-left:4px;"/>
                <t t-if="o.color">
                    &#160;&#160;<strong>COLOUR:</strong>
                    <span t-out="o.color" style="margin-left:4px;"/>
                </t>
            </td>
        </tr>
    </table>

    <!-- ══════════════════════════════════════════════════════
         CONSTRUCTION TITLE
    ══════════════════════════════════════════════════════ -->
    <table width="100%" style="border-collapse: collapse; border: 1.5px solid #222; border-top: 0;">
        <tr>
            <td style="text-align:center; font-weight:bold; font-size:13px;
                       padding: 6px; background:#f0f0f0; border-bottom: 1px solid #222;">
                CONSTRUCTION
            </td>
        </tr>
    </table>

    <!-- ══════════════════════════════════════════════════════
         MAIN BODY: Images + Details
    ══════════════════════════════════════════════════════ -->
    <table width="100%" style="border-collapse: collapse; border: 1.5px solid #222; border-top:0;">
        <tr>

            <!-- LEFT: Front image -->
            <td width="32%" style="border-right: 1px solid #ccc; padding: 8px; vertical-align: top; text-align:center;">
                <div style="font-weight:bold; color:#C0392B; margin-bottom:4px; font-size:10px;">FRONT VIEW</div>
                <t t-if="o.image_front">
                    <img t-att-src="image_data_uri(o.image_front)"
                         style="max-width:100%; max-height:320px; object-fit:contain;"/>
                </t>
                <t t-else="">
                    <div style="height:300px; border:1px dashed #aaa; color:#aaa; padding-top:130px;">
                        No front image
                    </div>
                </t>
            </td>

            <!-- MIDDLE: Construction details -->
            <td width="36%" style="border-right: 1px solid #ccc; padding: 8px; vertical-align: top; font-size:10px;">

                <!-- Fabric & Fit -->
                <table width="100%" style="border-collapse:collapse; margin-bottom:6px;">
                    <tr style="background:#f7f7f7;">
                        <td colspan="2" style="font-weight:bold; padding:3px 5px;
                            border-bottom:1px solid #ddd; font-size:11px;">
                            FABRIC &amp; FIT
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:3px 5px; color:#555; width:40%;">Fabric</td>
                        <td style="padding:3px 5px;">
                            <strong><span t-out="o.fabric"/></strong>
                        </td>
                    </tr>
                    <t t-if="o.fabric_composition">
                        <tr>
                            <td style="padding:3px 5px; color:#555;">Composition</td>
                            <td style="padding:3px 5px;"><span t-out="o.fabric_composition"/></td>
                        </tr>
                    </t>
                    <t t-if="o.fabric_weight">
                        <tr>
                            <td style="padding:3px 5px; color:#555;">Weight</td>
                            <td style="padding:3px 5px;"><span t-out="o.fabric_weight"/></td>
                        </tr>
                    </t>
                    <tr>
                        <td style="padding:3px 5px; color:#555;">Fit</td>
                        <td style="padding:3px 5px;">
                            <span t-out="dict(o._fields['fit_type'].selection).get(o.fit_type, o.fit_type or '')"/>
                        </td>
                    </tr>
                </table>

                <!-- Construction -->
                <table width="100%" style="border-collapse:collapse; margin-bottom:6px;">
                    <tr style="background:#f7f7f7;">
                        <td colspan="2" style="font-weight:bold; padding:3px 5px;
                            border-bottom:1px solid #ddd; font-size:11px;">
                            CONSTRUCTION
                        </td>
                    </tr>
                    <t t-if="o.collar_detail">
                        <tr>
                            <td style="padding:3px 5px; color:#C0392B; font-weight:bold; width:40%;">Collar</td>
                            <td style="padding:3px 5px;"><span t-out="o.collar_detail"/></td>
                        </tr>
                    </t>
                    <t t-if="o.pocket_detail">
                        <tr>
                            <td style="padding:3px 5px; color:#C0392B; font-weight:bold;">Pocket</td>
                            <td style="padding:3px 5px;"><span t-out="o.pocket_detail"/></td>
                        </tr>
                    </t>
                    <t t-if="o.closure_detail">
                        <tr>
                            <td style="padding:3px 5px; color:#C0392B; font-weight:bold;">Closure</td>
                            <td style="padding:3px 5px;"><span t-out="o.closure_detail"/></td>
                        </tr>
                    </t>
                    <t t-if="o.hem_detail">
                        <tr>
                            <td style="padding:3px 5px; color:#C0392B; font-weight:bold;">Hem</td>
                            <td style="padding:3px 5px;"><span t-out="o.hem_detail"/></td>
                        </tr>
                    </t>
                    <t t-if="o.elastic_detail">
                        <tr>
                            <td style="padding:3px 5px; color:#C0392B; font-weight:bold;">Elastic / Cuff</td>
                            <td style="padding:3px 5px;"><span t-out="o.elastic_detail"/></td>
                        </tr>
                    </t>
                </table>

                <!-- Stitching -->
                <table width="100%" style="border-collapse:collapse; margin-bottom:6px;">
                    <tr style="background:#f7f7f7;">
                        <td colspan="2" style="font-weight:bold; padding:3px 5px;
                            border-bottom:1px solid #ddd; font-size:11px;">
                            STITCHING
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:3px 5px; color:#555; width:40%;">Stitch Type</td>
                        <td style="padding:3px 5px;">
                            <span t-out="dict(o._fields['stitch_type'].selection).get(o.stitch_type, o.stitch_type or '')"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:3px 5px; color:#555;">SPI</td>
                        <td style="padding:3px 5px;">
                            <span t-out="o.stitch_spi"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:3px 5px; color:#555;">Seam Allowance</td>
                        <td style="padding:3px 5px;">
                            <span t-out="o.seam_allowance or ''"/> cm
                        </td>
                    </tr>
                    <t t-if="o.top_stitching">
                        <tr>
                            <td style="padding:3px 5px; color:#555;">Top Stitching</td>
                            <td style="padding:3px 5px;">
                                Yes
                                <t t-if="o.top_stitch_color">
                                    — <span t-out="o.top_stitch_color"/>
                                </t>
                            </td>
                        </tr>
                    </t>
                </table>

                <!-- Stitching note box -->
                <t t-if="o.stitching_notes">
                    <div style="border: 1px solid #C0392B; padding: 5px 7px;
                                color: #C0392B; font-weight: bold; font-size:10px; margin-top:4px;">
                        NOTE: <span t-out="o.stitching_notes" style="font-weight:normal; color:#111;"/>
                    </div>
                </t>

            </td>

            <!-- RIGHT: Back image + detail thumbnails -->
            <td width="32%" style="padding: 8px; vertical-align: top; text-align:center;">
                <div style="font-weight:bold; color:#C0392B; margin-bottom:4px; font-size:10px;">BACK VIEW</div>
                <t t-if="o.image_back">
                    <img t-att-src="image_data_uri(o.image_back)"
                         style="max-width:100%; max-height:260px; object-fit:contain;"/>
                </t>
                <t t-else="">
                    <div style="height:250px; border:1px dashed #aaa; color:#aaa; padding-top:110px;">
                        No back image
                    </div>
                </t>
                <t t-if="o.image_detail_1 or o.image_detail_2">
                    <table width="100%" style="margin-top:8px;">
                        <tr>
                            <t t-if="o.image_detail_1">
                                <td style="text-align:center; padding:2px;">
                                    <img t-att-src="image_data_uri(o.image_detail_1)"
                                         style="max-width:80px; max-height:80px; object-fit:contain; border:1px solid #ddd;"/>
                                </td>
                            </t>
                            <t t-if="o.image_detail_2">
                                <td style="text-align:center; padding:2px;">
                                    <img t-att-src="image_data_uri(o.image_detail_2)"
                                         style="max-width:80px; max-height:80px; object-fit:contain; border:1px solid #ddd;"/>
                                </td>
                            </t>
                        </tr>
                    </table>
                </t>
            </td>

        </tr>
    </table>

    <!-- ══════════════════════════════════════════════════════
         BOM / HARDWARE TABLE
    ══════════════════════════════════════════════════════ -->
    <t t-if="o.bom_line_ids">
        <table width="100%" style="border-collapse: collapse; border: 1.5px solid #222; border-top:0; margin-top:0;">
            <thead>
                <tr style="background:#222; color:#fff;">
                    <td colspan="9" style="padding:5px 8px; font-weight:bold; font-size:11px;">
                        BILL OF MATERIALS / HARDWARE &amp; TRIMS
                    </td>
                </tr>
                <tr style="background:#555; color:#fff; font-size:10px;">
                    <td style="padding:4px 6px; border:1px solid #777;">#</td>
                    <td style="padding:4px 6px; border:1px solid #777;">Type</td>
                    <td style="padding:4px 6px; border:1px solid #777;">Description</td>
                    <td style="padding:4px 6px; border:1px solid #777;">Colour / Finish</td>
                    <td style="padding:4px 6px; border:1px solid #777;">Size / Spec</td>
                    <td style="padding:4px 6px; border:1px solid #777;">Logo / Engraving</td>
                    <td style="padding:4px 6px; border:1px solid #777;">Placement</td>
                    <td style="padding:4px 6px; border:1px solid #777; text-align:right;">Qty</td>
                    <td style="padding:4px 6px; border:1px solid #777;">Notes</td>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="o.bom_line_ids" t-as="line">
                    <tr t-att-style="'background:#fafafa;' if line_index % 2 == 0 else 'background:#fff;'">
                        <td style="padding:3px 6px; border:1px solid #ddd; font-size:10px;">
                            <span t-out="line_index + 1"/>
                        </td>
                        <td style="padding:3px 6px; border:1px solid #ddd; font-size:10px;">
                            <span t-out="dict(line._fields['item_type'].selection).get(line.item_type, line.item_type or '')"/>
                        </td>
                        <td style="padding:3px 6px; border:1px solid #ddd; font-size:10px; font-weight:bold;">
                            <span t-out="line.name or ''"/>
                        </td>
                        <td style="padding:3px 6px; border:1px solid #ddd; font-size:10px;">
                            <span t-out="line.color or ''"/>
                        </td>
                        <td style="padding:3px 6px; border:1px solid #ddd; font-size:10px;">
                            <span t-out="line.size_spec or ''"/>
                        </td>
                        <td style="padding:3px 6px; border:1px solid #ddd; font-size:10px;">
                            <span t-out="line.logo_engraving or ''"/>
                        </td>
                        <td style="padding:3px 6px; border:1px solid #ddd; font-size:10px;">
                            <span t-out="line.placement or ''"/>
                        </td>
                        <td style="padding:3px 6px; border:1px solid #ddd; font-size:10px; text-align:right;">
                            <span t-out="'%.3g' % (line.qty or 0)"/>
                            <span t-out="line.uom_id.name or ''" style="margin-left:2px;"/>
                        </td>
                        <td style="padding:3px 6px; border:1px solid #ddd; font-size:10px;">
                            <span t-out="line.note or ''"/>
                        </td>
                    </tr>
                </t>
            </tbody>
        </table>
    </t>

    <!-- ══════════════════════════════════════════════════════
         LABEL & CARE
    ══════════════════════════════════════════════════════ -->
    <t t-if="o.label_position or o.label_content or o.care_instructions">
        <table width="100%" style="border-collapse:collapse; border:1.5px solid #222; border-top:0; margin-top:0;">
            <tr style="background:#f0f0f0;">
                <td colspan="2" style="padding:5px 8px; font-weight:bold;
                                       border-bottom:1px solid #222; font-size:11px;">
                    LABEL &amp; CARE INSTRUCTIONS
                </td>
            </tr>
            <tr>
                <t t-if="o.label_position">
                    <td style="padding:5px 8px; border-right:1px solid #ddd; width:50%; vertical-align:top;">
                        <strong style="color:#C0392B;">Label Position:</strong><br/>
                        <span t-out="o.label_position"/>
                    </td>
                </t>
                <t t-if="o.care_instructions">
                    <td style="padding:5px 8px; vertical-align:top;">
                        <strong style="color:#C0392B;">Care Instructions:</strong><br/>
                        <span t-out="o.care_instructions"/>
                    </td>
                </t>
            </tr>
            <t t-if="o.label_content">
                <tr>
                    <td colspan="2" style="padding:5px 8px; border-top:1px solid #ddd;">
                        <strong style="color:#C0392B;">Label Content:</strong>
                        <span t-out="o.label_content" style="margin-left:6px;"/>
                    </td>
                </tr>
            </t>
        </table>
    </t>

    <!-- ══════════════════════════════════════════════════════
         COSTING SECTION
    ══════════════════════════════════════════════════════ -->
    <table width="100%" style="border-collapse:collapse; border:1.5px solid #222; border-top:0; margin-top:0;">
        <tr style="background:#f0f0f0;">
            <td colspan="4" style="padding:5px 8px; font-weight:bold;
                                   border-bottom:1px solid #222; font-size:11px;">
                COSTING &amp; PRICING
            </td>
        </tr>
        <tr style="font-size:10px;">
            <td style="padding:5px 8px; border-right:1px solid #ddd; width:25%;">
                <span style="color:#555;">Fabric Cost</span><br/>
                <strong>
                    <span t-out="o.currency_id.symbol or ''"/>
                    <span t-out="'%.2f' % (o.fabric_cost or 0)"/>
                </strong>
            </td>
            <td style="padding:5px 8px; border-right:1px solid #ddd; width:25%;">
                <span style="color:#555;">Trim / Hardware</span><br/>
                <strong>
                    <span t-out="o.currency_id.symbol or ''"/>
                    <span t-out="'%.2f' % (o.trim_cost or 0)"/>
                </strong>
            </td>
            <td style="padding:5px 8px; border-right:1px solid #ddd; width:25%;">
                <span style="color:#555;">Labour + Overhead</span><br/>
                <strong>
                    <span t-out="o.currency_id.symbol or ''"/>
                    <span t-out="'%.2f' % ((o.labor_cost or 0) + (o.overhead_cost or 0))"/>
                </strong>
            </td>
            <td style="padding:5px 8px; width:25%; background:#fff8e1;">
                <span style="color:#555;">Total Cost</span><br/>
                <strong style="font-size:13px;">
                    <span t-out="o.currency_id.symbol or ''"/>
                    <span t-out="'%.2f' % (o.total_cost or 0)"/>
                </strong>
            </td>
        </tr>
        <tr style="font-size:10px; border-top:1px solid #ddd;">
            <td colspan="2" style="padding:5px 8px; border-right:1px solid #ddd;">
                <span style="color:#555;">Target Retail Price</span><br/>
                <strong style="font-size:13px;">
                    <span t-out="o.currency_id.symbol or ''"/>
                    <span t-out="'%.2f' % (o.target_price or 0)"/>
                </strong>
            </td>
            <td colspan="2" style="padding:5px 8px;">
                <span style="color:#555;">Margin</span><br/>
                <!-- <strong style="font-size:13px;">
                    <span t-att-style="'color:green;' if (o.margin_pct or 0) >= 40 else 'color:orange;'"
                          t-out="'%.1f%%' % (o.margin_pct or 0)"/>
                </strong> -->
            </td>
        </tr>
    </table>

    <!-- ══════════════════════════════════════════════════════
         APPROVAL FOOTER
    ══════════════════════════════════════════════════════ -->
    <table width="100%" style="border-collapse:collapse; border:1.5px solid #222; border-top:0; margin-top:0;">
        <tr style="font-size:10px;">
            <td style="padding:5px 8px; border-right:1px solid #ddd; width:25%;">
                <strong>Reference:</strong><br/>
                <span t-out="o.name"/>
            </td>
            <td style="padding:5px 8px; border-right:1px solid #ddd; width:25%;">
                <strong>Status:</strong><br/>
                <span t-out="dict(o._fields['state'].selection).get(o.state, o.state or '')"/>
            </td>
            <td style="padding:5px 8px; border-right:1px solid #ddd; width:25%;">
                <strong>Confirmed By:</strong><br/>
                <span t-out="o.confirmed_by.name or ''"/>
            </td>
            <td style="padding:5px 8px; width:25%;">
                <strong>Approved By:</strong><br/>
                <span t-out="o.approved_by.name or ''"/>
                <t t-if="o.approved_date">
                    &#160;on&#160;<span t-out="o.approved_date"/>
                </t>
            </td>
        </tr>
    </table>

</div>
</t>
</t>
</t>
</template>
</odoo>
