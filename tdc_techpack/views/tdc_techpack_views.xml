<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         FORM VIEW
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_tdc_techpack_form" model="ir.ui.view">
        <field name="name">tdc.techpack.form</field>
        <field name="model">tdc.techpack</field>
        <field name="arch" type="xml">
            <form string="Tech Pack">

                <!-- Status bar -->
                <header>
                    <button name="action_confirm"  string="Confirm"      type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve"  string="Approve"      type="object"
                            class="btn-primary"
                            invisible="state != 'confirm'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ['confirm','cancel']"/>
                    <button name="action_cancel"   string="Cancel"       type="object"
                            invisible="state in ['approved','cancel']"/>
                    <button name="action_print_techpack" string="🖨 Print Tech Pack"
                            type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirm,approved"/>
                </header>

                <sheet>
                    <!-- Smart buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_sale_orders" icon="fa-shopping-cart"
                                invisible="sale_count == 0">
                            <field name="sale_count" widget="statinfo" string="Sales"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_productions" icon="fa-cogs"
                                invisible="production_count == 0">
                            <field name="production_count" widget="statinfo" string="MO"/>
                        </button>
                    </div>

                    <!-- Title block -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- ── IDENTITY ──────────────────────────────────── -->
                    <group string="Identification">
                        <group>
                            <field name="brand"       placeholder="e.g. XANDER"/>
                            <field name="style_no"    placeholder="e.g. MENS_JACKET1"/>
                            <field name="description" placeholder="e.g. Jacket"/>
                            <field name="season"      placeholder="e.g. Fashion S/22"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="date"/>
                            <field name="size_range"  placeholder="XS/S/M/L/XL"/>
                            <field name="color"/>
                        </group>
                    </group>

                    <!-- ── FABRIC ───────────────────────────────────── -->
                    <group string="Fabric &amp; Material">
                        <group>
                            <field name="fabric"             placeholder="e.g. Blended Polyester"/>
                            <field name="fabric_weight"      placeholder="e.g. 280 GSM"/>
                            <field name="fabric_composition" placeholder="e.g. 60% Polyester 40% Cotton"/>
                        </group>
                        <group>
                            <field name="fit_type"/>
                        </group>
                    </group>

                    <!-- ── CONSTRUCTION ──────────────────────────────── -->
                    <group string="Construction Details">
                        <group>
                            <field name="collar_detail"  placeholder="e.g. Collar with Top Stitching"/>
                            <field name="pocket_detail"  placeholder="e.g. Classic Flap Pocket"/>
                            <field name="closure_type"/>
                            <field name="closure_detail" placeholder="e.g. Metal Zipper engraved with brand logo"/>
                        </group>
                        <group>
                            <field name="hem_detail"     placeholder="e.g. 3 cm hem"/>
                            <field name="elastic_detail" placeholder="e.g. Elastic band at cuffs"/>
                        </group>
                    </group>

                    <!-- ── STITCHING ─────────────────────────────────── -->
                    <group string="Stitching Specifications">
                        <group>
                            <field name="stitch_type"/>
                            <field name="stitch_spi"/>
                            <field name="seam_allowance"/>
                        </group>
                        <group>
                            <field name="top_stitching"/>
                            <field name="top_stitch_color"
                                   invisible="not top_stitching"
                                   placeholder="e.g. Matching / Contrast"/>
                        </group>
                        <field name="stitching_notes" colspan="2"
                               placeholder="e.g. All inside seam allowance sewn with Single Needle and Overlock Stitch"/>
                    </group>

                    <!-- ── NOTEBOOK ──────────────────────────────────── -->
                    <notebook>

                        <!-- Tab 1: BOM / Hardware -->
                        <page string="Bill of Materials" name="bom">
                            <field name="bom_line_ids" widget="one2many">
                                <list string="BOM Lines" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="item_type"/>
                                    <field name="name"/>
                                    <field name="color"/>
                                    <field name="size_spec"/>
                                    <field name="logo_engraving"/>
                                    <field name="placement"/>
                                    <field name="qty" sum="Total"/>
                                    <field name="uom_id"/>
                                    <field name="unit_cost"/>
                                    <field name="subtotal" sum="Total Cost"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab 2: Images -->
                        <page string="Technical Images" name="images">
                            <group>
                                <group string="Front View">
                                    <field name="image_front" widget="image"
                                           class="oe_avatar" options="{'size': [400, 500]}"/>
                                </group>
                                <group string="Back View">
                                    <field name="image_back" widget="image"
                                           class="oe_avatar" options="{'size': [400, 500]}"/>
                                </group>
                            </group>
                            <group>
                                <group string="Detail Image 1">
                                    <field name="image_detail_1" widget="image"
                                           options="{'size': [300, 300]}"/>
                                </group>
                                <group string="Detail Image 2">
                                    <field name="image_detail_2" widget="image"
                                           options="{'size': [300, 300]}"/>
                                </group>
                            </group>
                            <group string="Construction Notes">
                                <field name="construction_notes" widget="html" colspan="2"/>
                            </group>
                        </page>

                        <!-- Tab 3: Label & Care -->
                        <page string="Label &amp; Care" name="label">
                            <group>
                                <field name="label_position"    placeholder="e.g. Back neck, size label on side seam"/>
                                <field name="label_content"     placeholder="Brand name, size, country of origin"/>
                                <field name="care_instructions" placeholder="e.g. Machine wash 30°, Do not bleach"/>
                            </group>
                        </page>

                        <!-- Tab 4: Costing -->
                        <page string="Costing &amp; Pricing" name="costing">
                            <group string="Cost Breakdown">
                                <group>
                                    <field name="currency_id"/>
                                    <field name="fabric_cost"/>
                                    <field name="trim_cost"/>
                                </group>
                                <group>
                                    <field name="labor_cost"/>
                                    <field name="overhead_cost"/>
                                    <field name="total_cost" class="oe_subtotal_footer_separator"/>
                                </group>
                            </group>
                            <group string="Pricing">
                                <group>
                                    <field name="target_price"/>
                                    <field name="margin_pct" widget="percentage"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 5: Linked Documents -->
                        <page string="Linked Documents" name="traceability">
                            <group string="Sale Orders">
                                <field name="sale_order_ids" widget="many2many_tags"
                                       options="{'color_field': 'color'}"/>
                            </group>
                            <group string="Manufacturing Orders">
                                <field name="production_ids" widget="many2many_tags"/>
                            </group>
                            <group string="Approval Info" invisible="state not in ['confirm','approved']">
                                <field name="confirmed_by" readonly="1"/>
                                <field name="approved_by"  readonly="1"/>
                                <field name="approved_date" readonly="1"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         LIST VIEW
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_tdc_techpack_list" model="ir.ui.view">
        <field name="name">tdc.techpack.list</field>
        <field name="model">tdc.techpack</field>
        <field name="arch" type="xml">
            <list string="Tech Packs" decoration-success="state == 'approved'"
                  decoration-muted="state == 'cancel'"
                  decoration-warning="state == 'confirm'">
                <field name="name"/>
                <field name="brand"/>
                <field name="style_no"/>
                <field name="description"/>
                <field name="season"/>
                <field name="fabric"/>
                <field name="size_range"/>
                <field name="total_cost"/>
                <field name="target_price"/>
                <field name="margin_pct" widget="percentage"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'confirm'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         SEARCH VIEW
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_tdc_techpack_search" model="ir.ui.view">
        <field name="name">tdc.techpack.search</field>
        <field name="model">tdc.techpack</field>
        <field name="arch" type="xml">
            <search string="Search Tech Packs">
                <field name="name"/>
                <field name="brand"/>
                <field name="style_no"/>
                <field name="season"/>
                <field name="fabric"/>
                <field name="product_id"/>
                <separator/>
                <filter string="Draft"    name="draft"    domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirm" domain="[('state','=','confirm')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Brand"  name="by_brand"  context="{'group_by': 'brand'}"/>
                    <filter string="Season" name="by_season" context="{'group_by': 'season'}"/>
                    <filter string="Status" name="by_state"  context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         ACTION
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="action_tdc_techpack" model="ir.actions.act_window">
        <field name="name">Tech Packs</field>
        <field name="res_model">tdc.techpack</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Tech Pack
            </p>
            <p>
                A Tech Pack is the blueprint for your garment — fabric, construction,
                hardware BOM, stitching specs, costing and more.
            </p>
        </field>
    </record>

</odoo>
