<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_order_techpack_inherit" model="ir.ui.view">
        <field name="name">sale.order.techpack.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="action"
                        name="%(tdc_techpack.action_tdc_techpack)d"
                        icon="fa-file-text-o"
                        context="{'default_sale_order_ids': [(4, id)]}">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Tech Pack</span>
                    </div>
                </button>
            </div>
        </field>
    </record>

</odoo>